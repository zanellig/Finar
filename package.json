{
  "name": "finance-tracker-llm",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun build --compile --minify --outfile=fintracker src/server.ts",
    "build:linux": "bun build --compile --minify --target=bun-linux-x64 --outfile=dist/fintracker-linux src/server.ts",
    "build:macos": "bun build --compile --minify --target=bun-darwin-arm64 --outfile=dist/fintracker-macos src/server.ts",
    "build:windows": "bun build --compile --minify --target=bun-windows-x64 --windows-hide-console --outfile=dist/fintracker.exe src/server.ts",
    "build:all": "bun run build:linux && bun run build:macos && bun run build:windows",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
